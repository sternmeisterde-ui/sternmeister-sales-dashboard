{
  "name": "tmpapp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "mcp-server"
  ],
  "scripts": {
    "dev": "next dev -p 3008",
    "build": "next build",
    "start": "next start -p 3008",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate:analytics": "drizzle-kit generate --config=drizzle.analytics.config.ts",
    "db:migrate:analytics": "drizzle-kit migrate --config=drizzle.analytics.config.ts",
    "db:studio:analytics": "drizzle-kit studio --config=drizzle.analytics.config.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose logs -f",
    "analytics:backfill": "tsx scripts/backfill-analytics.ts",
    "analytics:backfill:range": "tsx scripts/backfill-analytics.ts",
    "analytics:backfill:comms": "tsx scripts/backfill-comms.ts"
  },
  "dependencies": {
    "@googleapis/drive": "^20.2.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/nextjs": "^10.45.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
