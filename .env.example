# Database Configuration (Required)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Node Environment (Optional - defaults to production in Docker)
NODE_ENV=production

# Application Port (Optional - defaults to 3008)
PORT=3008

# Kommo CRM Integration (Optional - for future use)
# KOMMO_CLIENT_ID=your_client_id
# KOMMO_CLIENT_SECRET=your_client_secret
# KOMMO_REDIRECT_URI=https://your-domain.com/api/kommo/callback
# KOMMO_SUBDOMAIN=your_subdomain

# AI Services (Optional - for future use)
# AI_API_KEY=your_api_key
# AI_API_URL=https://api.ai-service.com

# OKK (Call Quality Control) - Required for OKK tab
# R2 branch = B2B/Коммерсы, D2 branch = B2G/Госники
R2_OKK_DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
D2_OKK_DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Analytics DB (Neon "looker" project) — Kommo → analytics.* mirror fed by the
# in-house ETL. Required for Daily tab call metrics and Looker tab.
ANALYTICS_DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ETL cron — protects /api/analytics/sync/cron + drives the etl-cron sidecar.
# CRON_SECRET is the shared token; the sidecar sends it as x-cron-secret header.
CRON_SECRET=generate_with_openssl_rand_hex_32
# How often the etl-cron sidecar calls the sync endpoint (seconds, default 600 = 10 min).
# SYNC_INTERVAL_SECONDS=600
# Startup delay to let the app boot before the first sync (seconds, default 30).
# SYNC_START_DELAY_SECONDS=30
